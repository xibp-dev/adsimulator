# Salin file ini menjadi .env lalu isi dengan kredensial milikmu.
# JANGAN commit file .env yang berisi nilai asli (sudah di-ignore via .gitignore).

# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL="https://xxxxxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Database Postgres (Supabase > Project Settings > Database > Connection string)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# NextAuth — buat secret acak: openssl rand -base64 32
NEXTAUTH_SECRET="ganti-dengan-string-acak-yang-kuat"
NEXTAUTH_URL="http://localhost:3000"

# URL publik situs (dipakai untuk SEO, sitemap, robots)
NEXT_PUBLIC_SITE_URL="https://adsimulator.web.id"
